#!/bin/bash
# Find the browse binary. Echoes path and exits 0, or exits 1 if not found.
ROOT=$(git rev-parse --show-toplevel 2>/dev/null)

# Check relative to project root
if [ -n "$ROOT" ]; then
  for p in \
    "$ROOT/skills/browse/browse/dist/browse" \
    "$ROOT/.claude/skills/browse/browse/dist/browse" \
    "$ROOT/.claude/skills/gstack/browse/dist/browse"; do
    if test -x "$p"; then echo "$p"; exit 0; fi
  done
fi

# Check home directory
for p in \
  "$HOME/.claude/skills/browse/browse/dist/browse" \
  "$HOME/.claude/skills/gstack/browse/dist/browse"; do
  if test -x "$p"; then echo "$p"; exit 0; fi
done

echo "ERROR: browse binary not found. Run: cd skills/browse && ./setup" >&2
exit 1
