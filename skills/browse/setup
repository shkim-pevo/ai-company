#!/usr/bin/env bash
# browse setup — build browser binary + ensure Playwright Chromium
set -e

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
BROWSE_BIN="$SKILL_DIR/browse/dist/browse"

ensure_playwright_browser() {
  (
    cd "$SKILL_DIR"
    bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
  ) >/dev/null 2>&1
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SKILL_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$SKILL_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$SKILL_DIR/bun.lock" ] && [ "$SKILL_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  (
    cd "$SKILL_DIR"
    bun install
    bun run build
  )
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "browse setup failed: binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$SKILL_DIR"
    bunx playwright install chromium
  )
fi

if ! ensure_playwright_browser; then
  echo "browse setup failed: Playwright Chromium could not be launched" >&2
  exit 1
fi

echo "browse ready."
echo "  binary: $BROWSE_BIN"
